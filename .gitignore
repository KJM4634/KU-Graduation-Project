# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# Model artifacts (large, managed separately)
model/weights/*.pt
model/weights/*.onnx
model/weights/*.engine
*.pt
*.onnx
*.engine
runs/

# Training run artifacts (bulky, regenerable by rerunning train_yolo.py) -
# but keep small evaluation outputs (baseline JSON, report charts/JSON)
model/experiments/train/
model/experiments/calib/

# Dataset artifacts (large, downloaded/generated - see docs/DATASET.md)
model/data/raw/**
model/data/processed/**
model/data/synthetic/**
model/data/own_capture/**
model/data/splits/**
!model/data/raw/**/
!model/data/processed/**/
!model/data/synthetic/**/
!model/data/own_capture/**/
!model/data/splits/**/
!model/data/raw/**/.gitkeep
!model/data/processed/**/.gitkeep
!model/data/synthetic/**/.gitkeep
!model/data/own_capture/**/.gitkeep
!model/data/splits/**/.gitkeep

# Team handoff documents (hwp/hwpx) - 팀원들이 주고받는 한글 문서에 API 키 등
# 민감 정보가 평문으로 섞여 오는 경우가 있어 저장소에는 절대 포함하지 않음
*.hwp
*.hwpx

# Node (dashboard)
node_modules/
dist/
.env
.env.local

# Server
*.db
*.sqlite3
__pycache__/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs
*.log
